import random

# This program works like a Magic 8-Ball.
# The user can set their name and question, and the program gives a random answer.

name = "Joe"
question = ""

# Start with an empty answer.
answer = ""

# Pick a random number from 1 to 11.
# The number will decide which answer the Magic 8-Ball gives.
random_number = random.randint(1, 11)

# Match the random number to a possible Magic 8-Ball answer.
if random_number == 1:
    answer = "Yes - definitely"
elif random_number == 2:
    answer = "It is decidedly so"
elif random_number == 3:
    answer = "Without a doubt"
elif random_number == 4:
    answer = "Reply hazy, try again"
elif random_number == 5:
    answer = "Ask again later"
elif random_number == 6:
    answer = "Better not tell you now"
elif random_number == 7:
    answer = "My sources say no"
elif random_number == 8:
    answer = "Outlook not so good"
elif random_number == 9:
    answer = "Very doubtful"
elif random_number == 10:
    answer = "Arcade time"
elif random_number == 11:
    answer = "I love pizza"
else:
    answer = "Error"

# Check if the user forgot to ask a question.
if question == "":
    print("You didn't ask a question.")

# If there is no name, only print the question and answer.
elif name == "":
    print("Question: " + question)
    print("Magic 8-Ball's answer: " + answer)

# If both the name and question are provided, print everything normally.
else:
    print(name + " asks: " + question)
    print("Magic 8-Ball's answer: " + answer)

# This program simulates a simple furniture store checkout for one customer.
# It defines descriptions and prices for several products, then calculates
# the total cost of the items purchased by Customer One, including sales tax.
# The program also prints an itemized list of the purchased products along
# with the final total price.


# Product descriptions
lovely_loveseat_description = "Lovely Loveseat. Tufted polyester blend on wood. 32 inches high x 40 inches wide x 30 inches deep. Red or white."
stylish_settee_description = "Stylish Settee. Faux leather on birch. 29.50 inches high x 54.75 inches wide x 28 inches deep. Black."
luxurious_lamp_description = "Luxurious Lamp. Glass and iron. 36 inches tall. Brown with cream shade."

# Product prices
lovely_loveseat_price = 254.00
stylish_settee_price = 180.50
luxurious_lamp_price = 52.15

# Sales tax rate (8.8%)
sales_tax = 0.088

# Customer One's starting total (loveseat + lamp)
customer_one_total = 306.15

# Customer One's purchased items (combined description)
customer_one_itemization = (
    lovely_loveseat_description + " " + luxurious_lamp_description
)

# Calculate tax for Customer One
customer_one_tax = customer_one_total * sales_tax

# Add tax to the total
customer_one_total += customer_one_tax

# Print receipt for Customer One
print("Customer One Items:")
print(customer_one_itemization)

print("Customer One Total:")
print(customer_one_total)

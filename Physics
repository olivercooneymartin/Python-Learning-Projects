# This program performs basic physics calculations:
# temperature conversions, force, energy, and work.

# Given values

train_mass = 22680          # mass of the train (kg)
train_acceleration = 10     # acceleration of the train (m/s^2)
train_distance = 100        # distance traveled (meters)
bomb_mass = 1               # mass of the bomb (kg)

# Temperature conversion functions

# Convert Fahrenheit to Celsius
def f_to_c(f_temp):
    temp_c = (f_temp - 32) * 5 / 9
    return temp_c

# Convert Celsius to Fahrenheit
def c_to_f(c_temp):
    f_temp = c_temp * (9 / 5) + 32
    return f_temp

# Example conversions
f100_in_celsius = f_to_c(100)
c0_in_fahrenheit = c_to_f(0)

# Physics functions

# Calculate force using the formula: force = mass * acceleration
def get_force(mass, acceleration):
    return mass * acceleration

# Calculate energy using Einstein's formula: E = mc^2
# c is the speed of light (default value provided)
def get_energy(mass, c=3 * 10**8):
    return mass * (c ** 2)

# Calculate work using the formula: work = force * distance
def get_work(mass, acceleration, distance):
    # First calculate force
    force = get_force(mass, acceleration)
    # Then calculate work
    return force * distance

# Perform calculations

# Calculate force of the train
train_force = get_force(train_mass, train_acceleration)
print("The GE train supplies " + str(train_force) + " Newtons of force.")

# Calculate energy of the bomb
bomb_energy = get_energy(bomb_mass)
print("A 1kg bomb supplies " + str(bomb_energy) + " Joules.")

# Calculate work done by the train
train_work = get_work(train_mass, train_acceleration, train_distance)
print("The GE train does " + str(train_work) + " Joules of work over " + str(train_distance) + " meters.")

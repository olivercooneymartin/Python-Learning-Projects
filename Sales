# This program cleans and analyzes messy sales data.
# It calculates total sales and counts how many threads of each color were sold.

daily_sales = \
"""Edith Mcbride   ;,;$1.21   ;,;   white ;,; 
09/15/17   ,Herbert Tran   ;,;   $7.29;,; 
white&blue;,;   09/15/17 ,Paul Clarke ;,;$12.52 
;,;   white&blue ;,; 09/15/17 ,Lucille Caldwell   
;,;   $5.13   ;,; white   ;,; 09/15/17,
Eduardo George   ;,;$20.39;,; white&yellow 
;,;09/15/17   ,   Danny Mclaughlin;,;$30.82;,;   
purple ;,;09/15/17 ,Stacy Vargas;,; $1.85   ;,; 
purple&yellow ;,;09/15/17"""

# Replace the strange delimiter ";,;" with "+"
daily_sales_replaced = daily_sales.replace(";,;", "+")

# Split transactions by comma
daily_transactions = daily_sales_replaced.split(",")

# Split each transaction into parts (name, sale, colors, date)
daily_transactions_split = []

for transaction in daily_transactions:
  daily_transactions_split.append(transaction.split("+"))

# Clean whitespace and newline characters from each data point
transactions_clean = []

for transaction in daily_transactions_split:
  cleaned_transaction = []

  for data_point in transaction:
    cleaned_transaction.append(data_point.replace("\n", "").strip())

  transactions_clean.append(cleaned_transaction)

# Separate data into individual lists
customers = []
sales = []
thread_sold = []

for transaction in transactions_clean:
  customers.append(transaction[0])
  sales.append(transaction[1])
  thread_sold.append(transaction[2])

# Calculate total sales for the day
total_sales = 0

for sale in sales:
  total_sales += float(sale.strip("$"))

# Split thread colors into individual entries
thread_sold_split = []

for thread in thread_sold:
  for color in thread.split("&"):
    thread_sold_split.append(color)

# Function to count how many times a color appears
def color_count(color):
  count = 0

  for thread_color in thread_sold_split:
    if thread_color == color:
      count += 1

  return count

# Example: count white threads
print(color_count("white"))

# List of all colors to count
colors = ["red", "yellow", "green", "white", "black", "blue", "purple"]

# Print how many of each color were sold
for color in colors:
  print("There were " + str(color_count(color)) + " threads of " + color + " thread sold today.")
